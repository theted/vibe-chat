{
  "name": "ai-chat",
  "version": "1.0.0",
  "description": "Vibe chat application with multiple AI personalities and CLI tools",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "./start.sh",
    "cli": "bun run --filter @ai-chat/cli start",
    "build:configs": "turbo run build --filter=@ai-chat/ai-configs",
    "build:core": "turbo run build --filter=@ai-chat/core",
    "build:cli": "turbo run build --filter=@ai-chat/cli",
    "build:server": "turbo run build --filter=@ai-chat/server",
    "build:client": "turbo run build --filter=@ai-chat/client",
    "build": "turbo run build",
    "test": "turbo run test",
    "test:configs": "turbo run test --filter=@ai-chat/ai-configs",
    "test:core": "turbo run test --filter=@ai-chat/core",
    "test:client": "turbo run test --filter=@ai-chat/client",
    "test:cli": "turbo run test --filter=@ai-chat/cli",
    "test:server": "turbo run test --filter=@ai-chat/server",
    "test:e2e": "codeceptjs run --steps",
    "test:grok": "bun run --filter @ai-chat/core test:grok",
    "test:openai": "bun run --filter @ai-chat/core test:openai",
    "test:mistral": "bun run --filter @ai-chat/core test:mistral",
    "test:gemini": "bun run --filter @ai-chat/core test:gemini",
    "test:anthropic": "bun run --filter @ai-chat/core test:anthropic",
    "test:deepseek": "bun run --filter @ai-chat/core test:deepseek",
    "test:qwen": "bun run --filter @ai-chat/core test:qwen",
    "test:kimi": "bun run --filter @ai-chat/core test:kimi",
    "test:zai": "bun run --filter @ai-chat/core test:zai",
    "test:cohere": "bun run --filter @ai-chat/core test:cohere",
    "test:llama": "bun run --filter @ai-chat/core test:llama",
    "test:nvidia": "bun run --filter @ai-chat/core test:nvidia",
    "test:xiaomi": "bun run --filter @ai-chat/core test:xiaomi",
    "test:minimax": "bun run --filter @ai-chat/core test:minimax",
    "test:baidu": "bun run --filter @ai-chat/core test:baidu",
    "test:bytedance": "bun run --filter @ai-chat/core test:bytedance",
    "test:huggingface": "bun run --filter @ai-chat/core test:huggingface",
    "test:perplexity": "bun run --filter @ai-chat/core test:perplexity",
    "test:all": "bun run --filter @ai-chat/core test:all",
    "lint": "turbo run lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint:client": "turbo run lint --filter=@ai-chat/client",
    "lint:server": "turbo run lint --filter=@ai-chat/server",
    "lint:core": "turbo run lint --filter=@ai-chat/core",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:prod": "docker compose up --build",
    "docker:debug": "docker compose -f docker-compose.debug.yml up --build",
    "docker:clean": "docker compose down --volumes && docker system prune -f"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "codeceptjs": "^3.7.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "globals": "^13.24.0",
    "playwright": "^1.55.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ai",
    "chat",
    "realtime",
    "websocket",
    "react",
    "bun",
    "openai",
    "anthropic"
  ],
  "author": "AI Chat Team",
  "license": "MIT",
  "engines": {
    "bun": ">=1.2.0"
  },
  "overrides": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
