# Client environment variables
# Copy this file to .env.local for local overrides (never commit .env.local)

# Backend WebSocket/API URL.
# Defaults to same host as the frontend (works for production behind nginx).
# In local dev, auto-detected as http://localhost:3001 when running on port 3000.
# Override here to point at a remote backend instead of spinning up locally:
# VITE_SERVER_URL=https://vibe-api.sundbergsolutions.se

# Server port used for local URL auto-detection (only relevant when VITE_SERVER_URL is not set).
# Defaults to 3001.
# VITE_SERVER_PORT=3001

# Enable/disable private 1-on-1 conversations with AI participants.
# Accepts: true/false, 1/0, yes/no, on/off. Defaults to true.
# VITE_PRIVATE_CONVERSATIONS_ENABLED=true
